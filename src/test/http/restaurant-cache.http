    client.test("코스 목록 조회 1차 호출 성공", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
        client.assert(response.body.success === true, "success 값이 true가 아님");
    });

    client.log("코스 캐시 key 확인:");
