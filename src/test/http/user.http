user.http
### 환경변수 설정
@gatewayUrl = http://localhost:19000
# internal은 게이트웨이 거치지 않고 직접 호출
@internalUrl = http://localhost:19200
@reservationServiceUrl = http://localhost:19500
@timeSlotServiceUrl = http://localhost:19400
@catalogUrl = http://localhost:19800
@inventoryUrl = http://localhost:19900
@orderUrl = http://localhost:19700

### 테스트 USER 계정
@userLoginId = test95
@userPassword = test123!5
@userName = user95
@userEmail = user0095@naver.com
@userPhone = 010-1000-2005

### 레스토랑 조회 후 아래 변수에 응답값 입력
@courseUnitPrice = 100000.00

### 타임슬롯 조회 후 아래 변수에 응답값 입력
@timeSlotId = b184211a-bd71-478e-8f14-ce889ba9db1d
@targetDate = 2026-05-20
@slotStartTime = 10:00


### 1. USER 회원가입
POST {{gatewayUrl}}/api/v1/users/signup
Content-Type: application/json

{
  "loginId": "{{userLoginId}}",
  "password": "{{userPassword}}",
  "name": "{{userName}}",
  "email": "{{userEmail}}",
  "phone": "{{userPhone}}",
  "userRole": "USER"
}


### 2. USER 로그인
POST {{gatewayUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "loginId": "{{userLoginId}}",
  "password": "{{userPassword}}"
}

> {%
    client.global.clear("userToken");
    let token = null;
    if (response.body.data && response.body.data.accessToken) {
        token = response.body.data.accessToken;
    } else if (response.body.data && response.body.data.token) {
        token = response.body.data.token;
    } else if (response.body.accessToken) {
        token = response.body.accessToken;
    }
    if (token) {
        client.global.set("userToken", token);
    }
%}


### 3. 식당 검색 | 식당 목록 조회
GET {{gatewayUrl}}/api/v1/restaurants?keyword=MicheLet&region=강남&status=OPEN&page=0&size=10
Authorization: Bearer {{userToken}}

> {%
    client.global.clear("restaurantId");

    // 첫 번째 ID를 추출
    if (response.body && response.body.data && response.body.data.content && response.body.data.content.length > 0) {
        let firstId = response.body.data.content[0].restaurantId;
        client.global.set("restaurantId", firstId);
        client.log("새로 저장된 식당 ID: " + firstId);
    } else {
        client.log("에러: 검색 결과가 없어 ID를 저장하지 못했습니다.");
    }
%}

### 4. 식당 상세 조회
GET {{gatewayUrl}}/api/v1/restaurants/{{restaurantId}}
Authorization: Bearer {{userToken}}

### 5. 코스 목록 조회
GET {{gatewayUrl}}/api/v1/restaurants/{{restaurantId}}/courses
Authorization: Bearer {{userToken}}

> {%
    client.global.clear("courseId");

    if (response.body && response.body.data && response.body.data.length > 0) {
        // 첫 번째 코스의 ID 추출
        let firstCourseId = response.body.data[0].courseId;
        client.global.set("courseId", firstCourseId);
        client.log("Saved courseId: " + firstCourseId);
    } else {
        client.log("등록된 코스가 없거나 데이터를 찾을 수 없습니다.");
    }
%}

# 6. 타임슬롯 캘린더 조회

# 6-1 예약자 많은 경우

### 6-1-a 대기열 입장
POST {{gatewayUrl}}/api/v1/waitings
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
  "restaurantId": "{{restaurantId}}"
}

> {%
    client.global.clear("waitingId");
    client.global.clear("waitingToken");

    if (response.body && response.body.data) {
        let data = response.body.data;

        // waitingId 저장
        if (data.waitingId) {
            client.global.set("waitingId", data.waitingId);
            client.log("Saved waitingId: " + data.waitingId);
        }

        // token -> waitingToken 저장
        if (data.token) {
            client.global.set("waitingToken", data.token);
            client.log("Saved waitingToken: " + data.token);
        }
    } else {
        client.log("응답에서 데이터를 찾을 수 없습니다.");
    }
%}

### 6-1-ⅰ 대기 순번 조회
GET {{gatewayUrl}}/api/v1/waitings/status?token={{waitingToken}}
Authorization: Bearer {{userToken}}

> {%
    client.global.clear("waitingAccessToken");

    if (response.body && response.body.data) {
        let data = response.body.data;

        // 상태가 ACTIVE이고 accessToken이 발급되었는지 확인
        if (data.status === "ACTIVE" && data.accessToken) {
            client.global.set("waitingAccessToken", data.accessToken);
            client.log("입장 순서가 되었습니다! (ACTIVE)");
            client.log("Saved waitingAccessToken: " + data.accessToken);
        } else {
            // 아직 대기 중(WAITING)이거나 만료(EXPIRED)된 경우
            client.log("현재 대기 상태: " + data.status);
            client.log("남은 대기 순서: " + data.position + "번째");
        }
    } else {
        client.log("응답에서 데이터를 찾을 수 없습니다.");
    }
%}


### 6-1-ⅱ 대기 취소
DELETE {{gatewayUrl}}/api/v1/waitings/{{waitingId}}
Authorization: Bearer {{userToken}}

## 6-1-c 스케줄러를 통해 10초마다 입장용 토큰 발급 (자동 처리)


### 6-2 월간 예약 가능한 날짜 조회
GET {{gatewayUrl}}/api/v1/restaurants/{{restaurantId}}/time-slots/calendar?year=2026&month=4
Authorization: Bearer {{userToken}}

### 7. 특정 일자의 예약 가능한 타임 슬롯 목록 조회
GET {{gatewayUrl}}/api/v1/restaurants/{{restaurantId}}/time-slots?targetDate={{targetDate}}
Authorization: Bearer {{userToken}}


## 8. 예약 시간대 선택 후 예약 진행

### 8-1 예약 등록 api 호출
POST {{gatewayUrl}}/api/v1/reservations
Authorization: Bearer {{userToken}}
X-Waiting-Token: {{waitingToken}}
Content-Type: application/json

{
  "restaurantId": "{{restaurantId}}",
  "timeSlotId": "{{timeSlotId}}",
  "reservedDate": "{{targetDate}}",
  "slotStartTime": "{{slotStartTime}}",
  "guestCount": 2,
  "courses": [
    {
      "courseId": "{{courseId}}",
      "quantity": 2,
      "unitPrice": {{courseUnitPrice}}
    }
  ]
}

> {%
    client.global.clear("reservationId");

    client.test("예약 생성 성공", function () {
        client.assert(response.status === 201, "Expected 201 Created but got " + response.status);
        if (response.body && response.body.data) {
            client.assert(response.body.data.reservationId !== undefined, "reservationId 반환 확인");
        }
    });

    if (response.body && response.body.data && response.body.data.reservationId) {
        client.global.set("reservationId", response.body.data.reservationId);
        client.log("Saved reservationId: " + response.body.data.reservationId);
    }
%}

## 8-1-ⅰ 입장 가능 여부 검증 (이거는 예약 생성 내부에서 호출 시나리오 상에서 직접 호출 x)
# GET {{internalUrl}}/internal/waitings/verify-token?token={{waitingAccessToken}}

## 8-1-ⅱ 예약 확정 api 호출  (이거는 예약 생성 내부에서 호출 시나리오 상에서 직접 호출 x)
# POST {{waitingInternalUrl}}/internal/v1/time-slots/{{timeSlotId}}/deduct

## 8-1-ⅲ 예약 완료 후 토큰 삭제  (이거는 예약 생성 내부에서 호출 시나리오 상에서 직접 호출 x)
# DELETE {{internalUrl}}/internal/waitings/{{waitingId}}/complete


### 9. 예약 상세 조회
GET {{gatewayUrl}}/api/v1/reservations/{{reservationId}}
Authorization: Bearer {{userToken}}

> {%
    client.test("예약 상세 조회 성공", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(response.body.data.status === "CONFIRMED", "예약 상태 CONFIRMED 확인");
    });
%}


### 10. 다중 주문 요청 (이름 자동 생성 테스트 - "외 N건")
# owner.http에서 상품 등록(9번)을 먼저 진행하여 {{option_id_1}}이 세팅되어 있어야 함
POST {{gatewayUrl}}/api/v1/orders
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
    "restaurantId": "{{restaurantId}}",
    "reservationId": "{{reservationId}}",
    "receivingMethod": "PICKUP",
    "expiredAt": "2026-06-01T18:00:00",
    "items": [
        {
            "optionId": "{{option_id_1}}",
            "quantity": 2
        },
        {
            "optionId": "{{option_id_2}}",
            "quantity": 1
        }
    ]
}

> {%
    client.test("시스템 자동 이름 생성 확인 (상품 외 N건)", function () {
        client.assert(response.status === 200 || response.status === 201, "주문 생성 실패");
        var generatedName = response.body.data.orderName;
        client.assert(generatedName === "미슐랭 스페셜 코스 외 1건", "자동 생성 이름 오류: " + generatedName);
        client.log("다중 품목 자동 이름 생성 성공: " + generatedName);
    });
%}


### 11. 상품 전체 조회 (목록)
GET {{gatewayUrl}}/api/v1/products?page=0&size=10
Accept: application/json
Authorization: Bearer {{userToken}}

> {%
    client.test("전체 조회 성공", function () {
        client.assert(response.status === 200, "조회 실패");
        client.assert(response.body.content !== undefined, "데이터가 없습니다.");
    });
%}

### 12. 기간 만료 상품 단건 조회 (전시 상태 스케줄러 동기화 검증)
# owner.http의 12번(전시 상태 갱신 트리거) 실행 후 확인
GET {{gatewayUrl}}/api/v1/products/{{expired_product_id}}
Accept: application/json
Authorization: Bearer {{userToken}}

> {%
    client.test("카탈로그 스케줄러 동기화: 전시 상태 HIDDEN 변경 확인", function () {
        client.assert(response.status === 200, "조회 실패");
        var status = response.body.data.status;
        client.assert(status === "HIDDEN", "상태가 HIDDEN으로 동기화되지 않았습니다. 현재 상태: " + status);
        client.log("전시 상태 HIDDEN 변경 동기화 완료");
    });
%}

### 13. 정상 상품 단건 조회 (일일 재고 리셋 스케줄러 동기화 검증)
# owner.http의 13번(자정 리셋 트리거) 실행 후 확인
GET {{gatewayUrl}}/api/v1/products/{{depletion_product_id}}
Accept: application/json
Authorization: Bearer {{userToken}}

> {%
    client.test("한계 재고 리셋 로직(Math.min) 카탈로그 동기화 완벽 검증", function () {
        client.assert(response.status === 200, "카탈로그 조회 실패");
        var option = response.body.data.options[0];
        client.assert(option.totalQuantity === 5, "예상 총 재고: 5, 실제: " + option.totalQuantity);
        client.assert(option.currentDailyStock === 5, "예상 일일 재고(Math.min 적용): 5, 실제: " + option.currentDailyStock);
        client.log("최종 상태 - 총 재고: " + option.totalQuantity + " / 오늘 팔 수 있는 수량: " + option.currentDailyStock);
    });
%}


### 14. 품절(SOLDOUT) 자동 전이 동기화 검증
# owner.http의 14~17번(전체 재고 소진) 실행 후 확인
GET {{gatewayUrl}}/api/v1/products/{{depletion_product_id}}
Accept: application/json
Authorization: Bearer {{userToken}}

> {%
    client.test("카탈로그 동기화: SOLDOUT 상태 전이 확인", function () {
        client.assert(response.status === 200, "조회 실패");
        var data = response.body.data;
        var option = data.options[0];
        client.assert(option.totalQuantity === 0, "총 재고가 0이 아님");
        client.assert(data.status === "SOLDOUT", "상태가 SOLDOUT으로 동기화되지 않음");
        client.assert(data.isVisible === false, "SOLDOUT 상품은 isVisible이 false여야 함");
        client.log("재고 소진 시 SOLDOUT 자동 전이 동기화 성공");
    });
%}


### 15. 수정 및 삭제(Soft Delete) 동기화 검증
# owner.http의 18, 19번 실행 후 확인
GET {{gatewayUrl}}/api/v1/products/{{shared_product_id}}
Accept: application/json
Authorization: Bearer {{userToken}}

> {%
    client.test("카탈로그 동기화: 상품 정보 수정 및 삭제 확인", function () {
        client.assert(response.status === 200, "조회 실패");
        var data = response.body.data;
        client.assert(data.name === "수정된 미슐랭 코스", "이름 수정 동기화 실패");
        client.assert(data.status === "DELETED", "상태가 DELETED로 동기화되지 않음");
        client.assert(data.isVisible === false, "DELETED 상품은 isVisible이 false여야 함");
        client.log("상품 정보 수정 및 삭제 카프카 동기화 성공");
    });
%}