### 공통 변수
### 인증/회원가입/로그인은 Gateway 경유
@authUrl = http://localhost:19000

### 외부 API는 Gateway 경유
### @RequireRole이 붙은 API는 Gateway를 통해 인증 컨텍스트가 전달되어야 함
@restaurantExternalUrl = http://localhost:19000

### 내부 API는 restaurant-service 직접 호출
@restaurantInternalUrl = http://localhost:19300


### 테스트 OWNER 계정
@ownerLoginId = test9
@ownerPassword = test123!
@ownerName = owner9
@ownerEmail = owner009@naver.com
@ownerPhone = 010-0000-1007


### 테스트 USER 계정
@userLoginId = test8
@userPassword = test123!
@userName = user8
@userEmail = user008@naver.com
@userPhone = 010-0000-2006


### 0-0-1. OWNER 회원가입
### 식당 등록 / 코스 등록 테스트용 OWNER 계정 생성
POST {{authUrl}}/api/v1/users/signup
Content-Type: application/json

{
  "loginId": "{{ownerLoginId}}",
  "password": "{{ownerPassword}}",
  "name": "{{ownerName}}",
  "email": "{{ownerEmail}}",
  "phone": "{{ownerPhone}}",
  "userRole": "OWNER"
}


### 0-0-2. USER 회원가입
### 식당 목록/상세/코스 목록 조회 테스트용 USER 계정 생성
POST {{authUrl}}/api/v1/users/signup
Content-Type: application/json

{
  "loginId": "{{userLoginId}}",
  "password": "{{userPassword}}",
  "name": "{{userName}}",
  "email": "{{userEmail}}",
  "phone": "{{userPhone}}",
  "userRole": "USER"
}


### 0-1. OWNER 로그인
### 식당 등록 / 코스 등록에 사용할 OWNER 토큰 발급
POST {{authUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "loginId": "{{ownerLoginId}}",
  "password": "{{ownerPassword}}"
}

> {%
    client.global.clear("ownerToken");

    let token = null;

    if (response.body.data && response.body.data.accessToken) {
        token = response.body.data.accessToken;
    } else if (response.body.data && response.body.data.token) {
        token = response.body.data.token;
    } else if (response.body.accessToken) {
        token = response.body.accessToken;
    } else if (response.body.token) {
        token = response.body.token;
    }

    if (token) {
        client.global.set("ownerToken", token);
    }
%}


### 0-2. USER 로그인
### 식당 목록/상세 조회, 외부 코스 목록 조회에 사용할 USER 토큰 발급
POST {{authUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "loginId": "{{userLoginId}}",
  "password": "{{userPassword}}"
}

> {%
    client.global.clear("userToken");

    let token = null;

    if (response.body.data && response.body.data.accessToken) {
        token = response.body.data.accessToken;
    } else if (response.body.data && response.body.data.token) {
        token = response.body.data.token;
    } else if (response.body.accessToken) {
        token = response.body.accessToken;
    } else if (response.body.token) {
        token = response.body.token;
    }

    if (token) {
        client.global.set("userToken", token);
    }
%}


### 1. 식당 등록
POST {{restaurantExternalUrl}}/api/v1/restaurants
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "name": "MicheLet Dining",
  "address": "서울특별시 강남구 테헤란로 123",
  "phone": "02-1234-5678",
  "description": "파인다이닝 레스토랑",
  "reservationOpenAt": "10:00:00",
  "avgMealDurationMin": 90,
  "status": "OPEN",
  "businessHours": "MON-FRI 11:00-20:00 / SAT,SUN CLOSED"
}

> {%
    client.global.clear("restaurantId");

    if (response.status === 200 && response.body.data) {
        client.global.set("restaurantId", response.body.data.restaurantId);
    }
%}


### 2. 식당 목록/검색 조회
### USER 또는 OWNER 권한 필요
### 외부 API이므로 Gateway 경유
GET {{restaurantExternalUrl}}/api/v1/restaurants?keyword=MicheLet&region=강남구&status=OPEN&page=0&size=10
Authorization: Bearer {{userToken}}


### 3. 식당 상세 조회
### USER 또는 OWNER 권한 필요
### 외부 API이므로 Gateway 경유
GET {{restaurantExternalUrl}}/api/v1/restaurants/{{restaurantId}}
Authorization: Bearer {{userToken}}


### 4. 코스 등록
### OWNER 권한 필요
### 외부 API이므로 Gateway 경유
POST {{restaurantExternalUrl}}/api/v1/restaurants/{{restaurantId}}/courses
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "name": "Dinner Course",
  "price": 150000,
  "sessionType": "DINNER",
  "status": "AVAILABLE",
  "menus": [
    {
      "coursePart": "MAIN",
      "menuName": "양갈비",
      "sortOrder": 4
    },
    {
      "coursePart": "AMUSE_BOUCHE",
      "menuName": "한우 타르타르",
      "sortOrder": 1
    },
    {
      "coursePart": "APPETIZER",
      "menuName": "제철 샐러드",
      "sortOrder": 2
    },
    {
      "coursePart": "FISH",
      "menuName": "제철 생선 구이",
      "sortOrder": 3
    },
    {
      "coursePart": "DESSERT",
      "menuName": "바닐라 무스",
      "sortOrder": 5
    }
  ]
}

> {%
    client.global.clear("courseId");

    if (response.status === 200 && response.body.data) {
        client.global.set("courseId", response.body.data.courseId);
    }
%}


### 5. 외부 코스 목록 조회
### USER 또는 OWNER 권한 필요
### 외부 API는 menus[] 포함
### 외부 API이므로 Gateway 경유
GET {{restaurantExternalUrl}}/api/v1/restaurants/{{restaurantId}}/courses
Authorization: Bearer {{userToken}}


### 6. 존재하지 않는 식당의 외부 코스 목록 조회 - 404 확인
### USER 또는 OWNER 권한 필요
### 외부 API이므로 Gateway 경유
GET {{restaurantExternalUrl}}/api/v1/restaurants/00000000-0000-0000-0000-000000000000/courses
Authorization: Bearer {{userToken}}


### 7. 내부 식당 기본 정보 조회
### 내부 API는 @RequireRole 적용 대상 아님
### restaurant-service 직접 호출
GET {{restaurantInternalUrl}}/internal/v1/restaurants/{{restaurantId}}
X-Internal-Request: true


### 8. 내부 코스 목록 조회
### 내부 API는 menus[] 없이 menuComposition까지만 반환
### restaurant-service 직접 호출
GET {{restaurantInternalUrl}}/internal/v1/restaurants/{{restaurantId}}/courses
X-Internal-Request: true


### 9. 존재하지 않는 식당의 내부 코스 목록 조회 - 404 확인
### restaurant-service 직접 호출
GET {{restaurantInternalUrl}}/internal/v1/restaurants/00000000-0000-0000-0000-000000000000/courses
X-Internal-Request: true