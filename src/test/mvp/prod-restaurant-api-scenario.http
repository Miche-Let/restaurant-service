### 실행 전제:
### 1. API Gateway 터널 열기
###    ssh -N -i "C:\Users\...\...\michelet-bastion-key.cer" `
###    -L 19000:...:19000 `
###    ubuntu@...
###
### 목적:
### - Gateway → restaurant-service 라우팅 확인
### - OWNER 식당/코스 등록 확인
### - USER 식당 목록/상세/코스 조회 확인
### - 존재하지 않는 식당 조회 에러 응답 확인

@gatewayUrl = http://localhost:19000

### 테스트 OWNER 계정
@ownerLoginId = test90212
@ownerPassword = test123!0212
@ownerName = owner90212
@ownerEmail = owner0090212@naver.com
@ownerPhone = 010-0000-1013

### 테스트 USER 계정
@userLoginId = test99
@userPassword = test123!9
@userName = user99
@userEmail = user0099@naver.com
@userPhone = 010-1000-2009

### 테스트 식당/코스
@restaurantName = MicheLet Restaurant Scenario 100
@restaurantKeyword = MicheLet Restaurant Scenario
@courseName = Restaurant Scenario Dinner Course 100


### STEP RESET. 이전 테스트 global 변수 초기화
GET {{gatewayUrl}}/actuator/health

> {%
    client.global.clear("ownerToken");
    client.global.clear("userToken");
    client.global.clear("restaurantId");
    client.global.clear("courseId");

    client.log("restaurant API scenario global 변수 초기화 완료");
%}


### ─────────────────────────────────────────────
### STEP 0. API Gateway health 확인
### ─────────────────────────────────────────────
GET {{gatewayUrl}}/actuator/health

> {%
    client.log("Gateway health");
    client.log(response.body);

    client.test("Gateway health 확인", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
    });
%}


### ─────────────────────────────────────────────
### STEP 1. OWNER 회원가입
### 이미 가입된 계정이면 409 허용
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/users/signup
Content-Type: application/json

{
  "loginId": "{{ownerLoginId}}",
  "password": "{{ownerPassword}}",
  "name": "{{ownerName}}",
  "email": "{{ownerEmail}}",
  "phone": "{{ownerPhone}}",
  "userRole": "OWNER"
}

> {%
    client.log("OWNER 회원가입 응답");
    client.log(JSON.stringify(response.body, null, 2));

    client.test("OWNER 회원가입", function () {
        client.assert(
            response.status === 200 || response.status === 201 || response.status === 409,
            "Unexpected status: " + response.status
        );
    });
%}


### ─────────────────────────────────────────────
### STEP 2. OWNER 로그인
### ownerToken 저장
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "loginId": "{{ownerLoginId}}",
  "password": "{{ownerPassword}}"
}

> {%
    client.global.clear("ownerToken");

    let token = null;

    if (response.body && response.body.data && response.body.data.accessToken) {
        token = response.body.data.accessToken;
    } else if (response.body && response.body.data && response.body.data.token) {
        token = response.body.data.token;
    } else if (response.body && response.body.accessToken) {
        token = response.body.accessToken;
    } else if (response.body && response.body.token) {
        token = response.body.token;
    }

    if (!token) {
        client.log(JSON.stringify(response.body, null, 2));
        throw new Error("OWNER accessToken을 찾지 못했습니다.");
    }

    client.global.set("ownerToken", token);

    client.test("OWNER 로그인", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
        client.assert(token !== null, "ownerToken 저장 실패");
    });

    client.log("ownerToken saved");
%}


### ─────────────────────────────────────────────
### STEP 3. 식당 등록
### restaurantId 저장
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/restaurants
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "name": "{{restaurantName}}",
  "address": "서울특별시 강남구 테헤란로 456",
  "phone": "02-9876-5432",
  "description": "배포환경 restaurant-service 기본 API 시나리오 테스트용 식당",
  "reservationOpenAt": "10:00:00",
  "avgMealDurationMin": 90,
  "status": "OPEN",
  "businessHours": "MON-FRI 11:00-20:00 / SAT,SUN CLOSED"
}

> {%
    client.global.clear("restaurantId");

    const data = response.body && response.body.data ? response.body.data : null;
    const restaurantId = data && data.restaurantId ? data.restaurantId : null;

    client.log("식당 등록 응답");
    client.log(JSON.stringify(response.body, null, 2));

    client.test("식당 등록", function () {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200/201 but got " + response.status);
        client.assert(restaurantId !== null, "restaurantId 반환 없음");
    });

    client.global.set("restaurantId", restaurantId);
    client.log("restaurantId saved = " + restaurantId);
%}


### ─────────────────────────────────────────────
### STEP 4. 코스 등록
### courseId 저장
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/restaurants/{{restaurantId}}/courses
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "name": "{{courseName}}",
  "price": 180000,
  "sessionType": "DINNER",
  "status": "AVAILABLE",
  "menus": [
    {
      "coursePart": "AMUSE_BOUCHE",
      "menuName": "트러플 감자 크림",
      "sortOrder": 1
    },
    {
      "coursePart": "APPETIZER",
      "menuName": "참치 타르타르",
      "sortOrder": 2
    },
    {
      "coursePart": "FISH",
      "menuName": "전복 리조또",
      "sortOrder": 3
    },
    {
      "coursePart": "MAIN",
      "menuName": "한우 안심 스테이크",
      "sortOrder": 4
    },
    {
      "coursePart": "DESSERT",
      "menuName": "초콜릿 무스",
      "sortOrder": 5
    }
  ]
}

> {%
    client.global.clear("courseId");

    const data = response.body && response.body.data ? response.body.data : null;
    const courseId = data && data.courseId ? data.courseId : null;

    client.log("코스 등록 응답");
    client.log(JSON.stringify(response.body, null, 2));

    client.test("코스 등록", function () {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200/201 but got " + response.status);
        client.assert(courseId !== null, "courseId 반환 없음");
    });

    client.global.set("courseId", courseId);
    client.log("courseId saved = " + courseId);
%}


### ─────────────────────────────────────────────
### STEP 5. USER 회원가입
### 이미 가입된 계정이면 409 허용
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/users/signup
Content-Type: application/json

{
  "loginId": "{{userLoginId}}",
  "password": "{{userPassword}}",
  "name": "{{userName}}",
  "email": "{{userEmail}}",
  "phone": "{{userPhone}}",
  "userRole": "USER"
}

> {%
    client.log("USER 회원가입 응답");
    client.log(JSON.stringify(response.body, null, 2));

    client.test("USER 회원가입", function () {
        client.assert(
            response.status === 200 || response.status === 201 || response.status === 409,
            "Unexpected status: " + response.status
        );
    });
%}


### ─────────────────────────────────────────────
### STEP 6. USER 로그인
### userToken 저장
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "loginId": "{{userLoginId}}",
  "password": "{{userPassword}}"
}

> {%
    client.global.clear("userToken");

    let token = null;

    if (response.body && response.body.data && response.body.data.accessToken) {
        token = response.body.data.accessToken;
    } else if (response.body && response.body.data && response.body.data.token) {
        token = response.body.data.token;
    } else if (response.body && response.body.accessToken) {
        token = response.body.accessToken;
    } else if (response.body && response.body.token) {
        token = response.body.token;
    }

    if (!token) {
        client.log(JSON.stringify(response.body, null, 2));
        throw new Error("USER accessToken을 찾지 못했습니다.");
    }

    client.global.set("userToken", token);

    client.test("USER 로그인", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
        client.assert(token !== null, "userToken 저장 실패");
    });

    client.log("userToken saved");
%}


### ─────────────────────────────────────────────
### STEP 7. 식당 목록/검색 조회
### ─────────────────────────────────────────────
GET {{gatewayUrl}}/api/v1/restaurants?keyword={{restaurantKeyword}}&region=강남&status=OPEN&page=0&size=10
Authorization: Bearer {{userToken}}

> {%
    client.log("식당 목록 조회 응답");
    client.log(JSON.stringify(response.body, null, 2));

    client.test("식당 목록 조회", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
        client.assert(response.body && response.body.data, "data 없음");
    });
%}


### ─────────────────────────────────────────────
### STEP 8. 식당 상세 조회
### ─────────────────────────────────────────────
GET {{gatewayUrl}}/api/v1/restaurants/{{restaurantId}}
Authorization: Bearer {{userToken}}

> {%
    client.log("식당 상세 조회 응답");
    client.log(JSON.stringify(response.body, null, 2));

    client.test("식당 상세 조회", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
        client.assert(response.body && response.body.data, "data 없음");
        client.assert(response.body.data.restaurantId === client.global.get("restaurantId"),
            "restaurantId mismatch");
    });
%}


### ─────────────────────────────────────────────
### STEP 9. 코스 목록 조회
### ─────────────────────────────────────────────
GET {{gatewayUrl}}/api/v1/restaurants/{{restaurantId}}/courses
Authorization: Bearer {{userToken}}

> {%
    client.log("코스 목록 조회 응답");
    client.log(JSON.stringify(response.body, null, 2));

    client.test("코스 목록 조회", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
        client.assert(Array.isArray(response.body.data), "data가 배열이 아님");
        client.assert(response.body.data.length >= 1, "코스 목록이 비어 있음");
    });
%}


### ─────────────────────────────────────────────
### STEP 10. 존재하지 않는 식당 조회 실패 확인
### ─────────────────────────────────────────────
GET {{gatewayUrl}}/api/v1/restaurants/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{userToken}}

> {%
    client.log("존재하지 않는 식당 조회 응답");
    client.log(JSON.stringify(response.body, null, 2));

    client.test("존재하지 않는 식당 조회 실패 확인", function () {
        client.assert(response.status >= 400, "Expected 4xx/5xx but got " + response.status);
        client.assert(response.body && response.body.success === false,
            "실패 응답 success=false 확인 필요");
    });
%}