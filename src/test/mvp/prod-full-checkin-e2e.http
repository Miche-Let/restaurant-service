### ─────────────────────────────────────────────
### STEP 3. OWNER 로그인
### ownerToken, ownerId 저장
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "loginId": "{{ownerLoginId}}",
  "password": "{{ownerPassword}}"
}

> {%
    client.global.clear("ownerToken");
    client.global.clear("ownerId");

    let token = null;

    if (response.body && response.body.data && response.body.data.accessToken) {
        token = response.body.data.accessToken;
    } else if (response.body && response.body.data && response.body.data.token) {
        token = response.body.data.token;
    } else if (response.body && response.body.accessToken) {
        token = response.body.accessToken;
    } else if (response.body && response.body.token) {
        token = response.body.token;
    }

    if (!token) {
        client.log(JSON.stringify(response.body, null, 2));
        throw new Error("OWNER accessToken을 찾지 못했습니다.");
    }

    client.global.set("ownerToken", token);

    let payloadBase64 = token.split(".")[1].replace(/-/g, "+").replace(/_/g, "/");
    payloadBase64 += "=".repeat((4 - payloadBase64.length % 4) % 4);

    const payload = JSON.parse(atob(payloadBase64));

    client.global.set("ownerId", payload["sub"]);

    client.test("OWNER 로그인 성공", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
        client.assert(token !== null, "ownerToken 저장 실패");
    });

    client.log("ownerToken saved");
    client.log("ownerId saved = " + payload["sub"]);
%}


### ─────────────────────────────────────────────
### STEP 4. USER 로그인
### userToken, userId 저장
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "loginId": "{{userLoginId}}",
  "password": "{{userPassword}}"
}

> {%
    client.global.clear("userToken");
    client.global.clear("userId");

    let token = null;

    if (response.body && response.body.data && response.body.data.accessToken) {
        token = response.body.data.accessToken;
    } else if (response.body && response.body.data && response.body.data.token) {
        token = response.body.data.token;
    } else if (response.body && response.body.accessToken) {
        token = response.body.accessToken;
    } else if (response.body && response.body.token) {
        token = response.body.token;
    }

    if (!token) {
        client.log(JSON.stringify(response.body, null, 2));
        throw new Error("USER accessToken을 찾지 못했습니다.");
    }

    client.global.set("userToken", token);

    let payloadBase64 = token.split(".")[1].replace(/-/g, "+").replace(/_/g, "/");
    payloadBase64 += "=".repeat((4 - payloadBase64.length % 4) % 4);

    const payload = JSON.parse(atob(payloadBase64));

    client.global.set("userId", payload["sub"]);

    client.test("USER 로그인 성공", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
        client.assert(token !== null, "userToken 저장 실패");
    });

    client.log("userToken saved");
    client.log("userId saved = " + payload["sub"]);
%}


