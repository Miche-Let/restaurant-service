### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/users/signup
Content-Type: application/json

{
  "loginId": "{{ownerLoginId}}",
  "password": "{{ownerPassword}}",
  "name": "{{ownerName}}",
  "email": "{{ownerEmail}}",
  "phone": "{{ownerPhone}}",
  "userRole": "OWNER"
}

> {%
