### ─────────────────────────────────────────────
### STEP 7. 타임슬롯 일괄 생성
### 이미 생성된 시간대면 TS_008 / 409 가능 → 조회로 진행하면 됨
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/restaurants/{{restaurantId}}/time-slots/bulk
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "startDate": "{{reservedDate}}",
  "endDate": "{{reservedDate}}",
  "openTime": "{{slotOpenTime}}",
  "closeTime": "{{slotCloseTime}}",
  "intervalMinutes": {{slotIntervalMinutes}},
  "capacity": {{slotCapacity}}
}

> {%
    client.log("타임슬롯 일괄 생성 응답");
    client.log(JSON.stringify(response.body, null, 2));

    client.test("타임슬롯 일괄 생성 또는 기존 슬롯 존재 확인", function () {
        client.assert(
            response.status === 200 ||
            response.status === 201 ||
            response.status === 409,
            "Expected 200/201/409 but got " + response.status
        );
    });

    if (response.status === 409) {
        client.log("이미 해당 시간대 타임슬롯이 존재하므로 STEP 8 조회로 진행합니다.");
    } else {
        client.assert(response.body.success === true, "타임슬롯 생성 success=false");
    }
%}


### ─────────────────────────────────────────────
### STEP 8. 타임슬롯 조회
### slotStartTime과 정확히 일치하는 슬롯을 찾고
### 출력된 @timeSlotId / @selectedSlotStartTime 값을 파일 상단에 수동 입력
### ─────────────────────────────────────────────
GET {{gatewayUrl}}/api/v1/restaurants/{{restaurantId}}/time-slots?targetDate={{reservedDate}}
Authorization: Bearer {{userToken}}

> {%
    client.log("타임슬롯 조회 응답");
    client.log(JSON.stringify(response.body, null, 2));

    const slots = response.body && response.body.data ? response.body.data : [];
    const targetStartTime = "{{slotStartTime}}";

    let selected = null;

    for (const slot of slots) {
        if (slot.startTime === targetStartTime || slot.slotStartTime === targetStartTime) {
            selected = slot;
            break;
        }
    }

    client.test("타임슬롯 조회 성공", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
        client.assert(Array.isArray(slots), "data가 배열이 아님");
        client.assert(slots.length > 0, "timeSlot 목록이 비어 있음");
    });

    client.test("slotStartTime과 일치하는 타임슬롯 선택", function () {
        client.assert(
            selected !== null,
            "slotStartTime=" + targetStartTime + " 과 일치하는 timeSlot이 없음"
        );
    });

    if (selected) {
        client.log("아래 두 줄을 파일 상단에 복사하세요.");
        client.log("@timeSlotId = " + selected.timeSlotId);
        client.log("@selectedSlotStartTime = " + selected.startTime);
    }
%}


### ─────────────────────────────────────────────
### STEP 9. 대기열 입장
### queueToken 저장
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/waitings
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
  "restaurantId": "{{restaurantId}}"
}

> {%
    client.global.clear("queueToken");
    client.global.clear("waitingId");
    client.global.clear("waitingAccessToken");

    client.log("대기열 입장 응답");
    client.log(JSON.stringify(response.body, null, 2));

    const data = response.body && response.body.data ? response.body.data : null;

    client.test("대기열 입장 성공", function () {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200/201 but got " + response.status);
        client.assert(data !== null, "data 없음");
        client.assert(data.token !== undefined, "대기열 token 없음");
    });

    client.global.set("queueToken", data.token);
    client.global.set("waitingId", data.waitingId);

    client.log("queueToken saved = " + data.token);
    client.log("waitingId saved = " + data.waitingId);
%}


### ─────────────────────────────────────────────
### STEP 10. 대기열 상태 조회
### status가 ACTIVE가 되고 accessToken이 내려올 때까지
### 10초 간격으로 여러 번 실행
### ─────────────────────────────────────────────
GET {{gatewayUrl}}/api/v1/waitings/status?token={{queueToken}}
Authorization: Bearer {{userToken}}

> {%
    client.log("대기열 상태 조회 응답");
    client.log(JSON.stringify(response.body, null, 2));

    const data = response.body && response.body.data ? response.body.data : null;

    client.test("대기열 상태 조회 성공", function () {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
        client.assert(data !== null, "data 없음");
        client.assert(data.status !== undefined, "status 없음");
    });

    if (data && data.status === "ACTIVE" && data.accessToken) {
        client.global.set("waitingAccessToken", data.accessToken);
        client.log("waitingAccessToken saved = " + data.accessToken);
    } else {
        client.log("아직 ACTIVE가 아니거나 accessToken 없음. 10초 뒤 STEP 10을 다시 실행하세요.");
    }
%}


### ─────────────────────────────────────────────
### STEP 11. 예약 생성
###
### X-Waiting-Token에는 queueToken이 아니라
### STEP 10에서 받은 waitingAccessToken을 넣어야 함
### ─────────────────────────────────────────────
POST {{gatewayUrl}}/api/v1/reservations
Content-Type: application/json
Authorization: Bearer {{userToken}}
X-Waiting-Token: {{waitingAccessToken}}
Idempotency-Key: reservation-full-e2e-90212-{{$timestamp}}

{
  "restaurantId": "{{restaurantId}}",
  "timeSlotId": "{{timeSlotId}}",
  "reservedDate": "{{reservedDate}}",
  "slotStartTime": "{{selectedSlotStartTime}}",
  "guestCount": 2,
  "courses": [
    {
      "courseId": "{{courseId}}",
      "quantity": 1,
      "unitPrice": 150000
    }
  ]
}

> {%
    client.global.clear("reservationId");

    client.log("예약 생성 응답");
    client.log(JSON.stringify(response.body, null, 2));

    const data = response.body && response.body.data ? response.body.data : null;
    const reservationId = data && data.reservationId ? data.reservationId : null;

    client.test("예약 생성 성공", function () {
        client.assert(response.status === 200 || response.status === 201,
            "Expected 200/201 but got " + response.status);
        client.assert(response.body.success === true, "예약 생성 success=false");
        client.assert(reservationId !== null, "reservationId 반환 없음");
    });

    client.global.set("reservationId", reservationId);
    client.log("reservationId saved = " + reservationId);
%}


